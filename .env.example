POKEPY_AUTO_CREATE_TABLES=true
POKEPY_API_HOST=127.0.0.1
POKEPY_API_PORT=8000
POKEPY_API_TITLE=PokePY API
POKEPY_API_VERSION=4.0.0
POKEPY_LOG_LEVEL=INFO
POKEPY_CORS_ORIGINS=["*"]
POKEPY_LEADERBOARD_MAX_ENTRIES=100
